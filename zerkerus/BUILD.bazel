cc_library(
    name = "zerkerus_fbs_wrapper",
    deps = [":zerkerus_fbs"],
    defines = ["__building_module(x)=0"],
)

cc_library(
    name = "zerkerus_fbs_bridge",
    srcs = ["zerkerus_fbs_bridge.c"],
    hdrs = ["zerkerus_fbs_bridge.h"],
    deps = [":zerkerus_fbs_wrapper"],
